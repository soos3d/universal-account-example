# EVM private key, used by ethers.Wallet
PRIVATE_KEY=

# Particle Network project credentials — get these from https://dashboard.particle.network/
PROJECT_ID=
PROJECT_CLIENT_KEY=
PROJECT_APP_UUID=

# RPC URLs for specific chains — required by EIP-7702 examples
# Add entries for each chain you need, e.g. EVM_RPC_56 for BSC, EVM_RPC_137 for Polygon
EVM_RPC_137=https://polygon-rpc.com/

# Override the SDK smart account version (optional, defaults to the SDK constant)
# UNIVERSAL_ACCOUNT_VERSION=

# Override the WebSocket endpoint (optional)
# UNIVERSALX_WSS_URL=wss://universal-app-ws-proxy.particle.network
